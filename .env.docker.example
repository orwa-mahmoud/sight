# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=frontdesk_db

# ── Application ───────────────────────────────────────────────────
APP_NAME=frontdesk
APP_ENV=production
LOG_LEVEL=INFO

# ── Database (uses Docker service names as hosts) ─────────────────
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────
# IMPORTANT: generate a real secret before deploying.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE-ME-generate-a-256-bit-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Encryption (Fernet key for tenant secrets at rest) ────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Rotation: put the NEW key in ENCRYPTION_KEY and the previous key(s) here
# (comma-separated). Old ciphertext keeps decrypting until you re-encrypt + drop it.
# ENCRYPTION_KEY_FALLBACKS=

# ── Observability ─────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=frontdesk-backend
SENTRY_DSN=

# ── CORS ──────────────────────────────────────────────────────────
# In Docker the frontend talks to the API same-origin via the nginx proxy, so
# CORS is not strictly needed; kept here for direct API access during testing.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────
# Not needed for the Docker build: the nginx-served frontend uses same-origin
# relative URLs (/api, /webhooks) which nginx reverse-proxies to the backend.
# Set this only if you serve the API from a different origin.
# VITE_API_URL=
