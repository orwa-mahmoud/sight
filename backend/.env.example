# ── Application ───────────────────────────────────────────────────
APP_NAME=sight
APP_ENV=development
LOG_LEVEL=INFO

# ── Database (PostgreSQL 17 + pgvector) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sight_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/sight_db
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5432/sight_test

# ── Redis (thread locking, rate limit, ingestion job queue) ───────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-256-bit-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Encryption (Fernet key for tenant secrets at rest) ────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in production (startup fails without it); optional in dev (empty =
# secrets stored as plaintext).
ENCRYPTION_KEY=
# Rotating the key: move the OLD key here (comma-separated for multiple) so existing
# ciphertext keeps decrypting, then re-save records and drop it. Removing a key that
# stored data still needs is caught at startup (if malformed) or via the
# sight_crypto_decrypt_failures_total metric (if a needed fallback is missing).
ENCRYPTION_KEY_FALLBACKS=

# ── Platform admin bootstrap ──────────────────────────────────────
# If set, the user with this email is granted platform super-admin on startup.
# You can also use: python -m src.cli admin grant <email>
PLATFORM_ADMIN_EMAIL=

# ── Frontend ──────────────────────────────────────────────────────
# Public base URL of the web app; used to build invitation links.
FRONTEND_BASE_URL=http://localhost:5173

# ── Uploads / ingestion jobs ──────────────────────────────────────
# Where raw uploaded files are streamed to disk. Must be a shared volume between
# the web and the worker; files live at <dir>/<tenant_id>/<document_id>.
UPLOAD_STORAGE_DIR=var/uploads
# Seconds a document may sit uploaded/ingesting before the reaper re-enqueues it.
INGESTION_STALE_AFTER_SECONDS=900

# ── CORS (frontend dev server) ────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
