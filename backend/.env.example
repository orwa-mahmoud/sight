# ── Application ───────────────────────────────────────────────────
APP_NAME=frontdesk
APP_ENV=development
LOG_LEVEL=INFO

# ── Database (PostgreSQL 17 + pgvector) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/frontdesk_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/frontdesk_db
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5432/frontdesk_test

# ── Redis (thread locking, rate limit) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-256-bit-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Encryption (Fernet key for tenant secrets at rest) ────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty in dev to store secrets as plaintext.
ENCRYPTION_KEY=

# ── Observability ─────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=frontdesk-backend
SENTRY_DSN=

# ── CORS (frontend dev server) ────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
