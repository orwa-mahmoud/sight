# ── Application ───────────────────────────────────────────────────
APP_NAME=frontdesk
APP_ENV=development
LOG_LEVEL=INFO

# ── Database (PostgreSQL 17 + pgvector) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/frontdesk_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/frontdesk_db
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5432/frontdesk_test

# ── Redis (thread locking, rate limit) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-256-bit-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM providers (set whichever you use; the LLMClientPort
#    factory selects per-tenant via DB-stored credentials in prod) ─
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Default model for tenants without a custom config.
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Default embedding model for the RAG ingestion pipeline.
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large
DEFAULT_EMBEDDING_DIMENSIONS=3072

# ── Channels ──────────────────────────────────────────────────────
# WhatsApp Cloud API (Meta) — per-tenant config lives in DB; these
# are global fallback / verification token for the webhook.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Telegram Bot API — per-tenant bot token in DB; this is the
# webhook verification secret.
TELEGRAM_WEBHOOK_SECRET=

# ── Observability ─────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=frontdesk-backend
SENTRY_DSN=

# ── CORS (frontend dev server) ────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
