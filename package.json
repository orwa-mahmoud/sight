{
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^16.1.0"
  },
  "lint-staged": {
    "backend/**/*.py": [
      "bash -c 'cd backend && uv run ruff check --fix \"$@\"' _",
      "bash -c 'cd backend && uv run ruff format \"$@\"' _"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npx eslint --fix \"$@\"' _"
    ]
  }
}
